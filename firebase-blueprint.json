{
  "entities": {
    "Appointment": {
      "title": "Appointment",
      "description": "A dental appointment request.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the patient."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the patient."
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the patient."
        },
        "service": {
          "type": "string",
          "description": "The dental service requested (e.g., general, cosmetic)."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "Preferred date for the appointment."
        },
        "time": {
          "type": "string",
          "description": "Preferred time for the appointment."
        },
        "message": {
          "type": "string",
          "description": "Optional message from the patient."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "confirmed", "cancelled"],
          "description": "Current status of the appointment."
        },
        "userId": {
          "type": "string",
          "description": "The UID of the user who booked the appointment (if logged in)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the appointment was requested."
        }
      },
      "required": ["name", "email", "phone", "service", "date", "time", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A registered user of the dental clinic website.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile photo URL."
        },
        "role": {
          "type": "string",
          "enum": ["patient", "admin"],
          "description": "The user's role in the system."
        }
      },
      "required": ["displayName", "email", "role"]
    }
  },
  "firestore": {
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Collection of dental appointment requests."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of registered users."
    }
  }
}
